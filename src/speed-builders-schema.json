{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "structures": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "properties": {
            "difficulty": {
              "type": "string",
              "description": "Difficulty of the structure.",
              "enum": [
                "EASY",
                "MEDIUM",
                "HARD",
                "INSANE"
              ]
            }
          },
          "required": [
            "difficulty"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "structures"
  ],
  "additionalProperties": false
}